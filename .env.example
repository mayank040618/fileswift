
# Frontend (Vercel)
# Canonical backend origin for tool uploads/polling/feedback.
# Do not include trailing slash or /api.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Legacy fallback (supported for backward compatibility).
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_LOAD_CONSENT_REQUIRED=true
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# AI Integration (Grok/xAI)
XAI_API_KEY=

# Azure AI (Phi-4-mini via Azure AI Foundry)
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=
AZURE_AI_MODEL=Phi-4-mini-instruct

# Backend (Render)
PORT=8080
PUBLIC_API_URL=https://fileswift-backend.onrender.com
MAX_UPLOAD_FILES=100
MAX_UPLOAD_FILESIZE=104857600
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
REDIS_URL=
